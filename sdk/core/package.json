{
  "name": "@cookieyes/core",
  "version": "0.1.1",
  "description": "Headless consent engine — the single source of truth for all CookieYes consent logic",
  "keywords": [
    "cookie consent",
    "GDPR",
    "CCPA",
    "cookie banner",
    "consent management",
    "privacy",
    "compliance",
    "React",
    "Next.js",
    "TypeScript",
    "open source"
  ],
  "homepage": "https://github.com/cookieyes/cookieyes/tree/main/sdk/core#readme",
  "bugs": {
    "url": "https://github.com/cookieyes/cookieyes/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cookieyes/cookieyes.git",
    "directory": "sdk/core"
  },
  "license": "MIT",
  "author": "CookieYes (https://www.cookieyes.com)",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rm -rf dist && rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}

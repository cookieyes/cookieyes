{
  "name": "@cookieyes/nextjs",
  "version": "0.2.0",
  "description": "Next.js App Router adapter for the CookieYes consent SDK",
  "keywords": [
    "cookie consent",
    "GDPR",
    "CCPA",
    "cookie banner",
    "consent management",
    "privacy",
    "compliance",
    "React",
    "Next.js",
    "TypeScript",
    "open source"
  ],
  "homepage": "https://github.com/cookieyes/cookieyes/tree/main/sdk/nextjs#readme",
  "bugs": {
    "url": "https://github.com/cookieyes/cookieyes/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cookieyes/cookieyes.git",
    "directory": "sdk/nextjs"
  },
  "license": "MIT",
  "author": "CookieYes (https://www.cookieyes.com)",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rm -rf dist && rollup -c",
    "dev": "rollup -c -w",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@cookieyes/core": "workspace:*",
    "@cookieyes/react": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
